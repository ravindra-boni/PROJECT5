{
  "_version": "1.17.0",
  "sap.app": {
    "id": "project5",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.24.0",
      "toolsId": "dbadf251-2840-41b3-af27-4f2897edf47a"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZEMP_ATTEND_SRV_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      },
      "ZTRAIN_BOOKING_SRV": {
        "uri": "/sap/opu/odata/sap/ZTRAIN_BOOKING_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/ZTRAIN_BOOKING_SRV/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "zslot-display": {
          "semanticObject": "zslot",
          "action": "display",
          "title": "{{zslot-display.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.71.19",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.viz": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "project5.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      },
      "ZTRAIN_BOOKING_SRV": {
        "dataSource": "ZTRAIN_BOOKING_SRV",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "project5.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteEmployee",
          "pattern": " ",
          "target": [
            "TargetEmployee"
          ]
        },
        {
          "name": "Frame",
          "pattern": "Frame",
          "target": [
            "TargetFrame"
          ]
        },
        {
          "name": "Slot",
          "pattern": "Slot",
          "target": [
            "TargetSlot"
          ]
        },
        {
          "name": "Task",
          "pattern": "Task",
          "target": [
            "TargetTask"
          ]
        },
        {
          "name": "Frame",
          "pattern": "Frame",
          "target": [
            "TargetFrame"
          ]
        },
        {
          "name": "Property",
          "pattern": "Property",
          "target": [
            "TargetProperty"
          ]
        },
        {
          "name": "Practice",
          "pattern": "Practice",
          "target": [
            "TargetPractice"
          ]
        }
      ],
      "targets": {
        "TargetEmployee": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "Employee",
          "viewName": "Employee"
        },
        "TargetFrame": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "Frame",
          "viewName": "Frame"
        },
        "TargetProperty": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "Property",
          "viewName": "Property"
        },
        "TargetTask": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "Task",
          "viewName": "Task"
        },
        "TargetSlot": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "Slot",
          "viewName": "Slot"
        },
        "TargetPractice": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "Practice",
          "viewName": "Practice"
        }
      }
    },
    "rootView": {
      "viewName": "project5.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "project5"
  }
}
