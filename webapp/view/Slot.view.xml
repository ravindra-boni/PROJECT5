<mvc:View
    controllerName="project5.controller.Slot"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="Training Room Slot Booking System">

        <content>

            <VBox class="sapUiSizeCompact sapUiMediumMargin">
<Title text="TRAINING ROOM BOOKING SYSTEM" level="H2"/>
                <!-- Resource Type -->
           <Label text="Select Resource" />
<ComboBox id="resources" selectedKey="Training Room">
   <items>
    <core:Item key="Training Room" text="Training Room" />
    </items>
</ComboBox>


                <!-- Employee -->
                <Label text="Department" />

                <ComboBox id="deptt" items="{/department}">
                    <core:Item key="{department}" text="{department}" />

                </ComboBox>
<VBox  class="sapUiSizeCompact sapUiMediumMargin">
                <!-- Department -->
                <Label text="Employee" />
                <Input id="emps" placeholder="Enter Employee Name" />

                <!-- Date -->
                <Label text="Date" class="smallText" />
                <DatePicker id="datee" class="smallLabel" />
                
                 <Label text="Time" />
          <Input id="time" placeholder="Select Slot"/>

        <Label text="Capacity"  class="sapUiTinyMarginTop smallLabel"/>
                <Input id="capacity_of_members" type="Number" />
                

         <Label text="Available Slots" class="sapUiSmallMarginTop"/>    

        </VBox>

                <HBox
                 wrap="Wrap">
                   <Button text="09:00 AM" press="onSelectSlot"/>
 <Button text="10:00 AM" press="onSelectSlot"/>
  <Button text="11:00 AM" press="onSelectSlot"/>
 <Button text="12:00 PM" press="onSelectSlot"/>
                </HBox>

                <HBox class="sapUiSmallMarginTop">

                    <Button text="Book Slot" type="Emphasized" press="onBook" />
                    <Button text="Fetch BOOKED SLOT" press="onFetchBOOKED SLOT" />

    <Button text="Reset" type="Reject" press="onReset" />
                </HBox>


            </VBox>

            
            <VBox>
            <Title text="BOOKED SLOTS" level="H3"/>
            <List  id = "bookingsList" items="{/bookings}" class="sapUiSmallMarginTop">

                <StandardListItem
                    title="{employee} - {resource}"
                    description="{date} |{time}| {department} |Capacity:  {capacity}" />

            </List>
            </VBox>

        </content>
        
    </Page>
</mvc:View>

