<mvc:View
    controllerName="project5.controller.Task"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="Training Room Slot Booking System">

        <content>

            <VBox class="sapUiSizeCompact sapUiMediumMargin">

                <Title text="TRAINING ROOM BOOKING SYSTEM" level="H2"/>

                <!-- Resource -->
                <Label text="Select Resource" />
                <ComboBox id="resource" selectedKey="Training Room">
                    <items>
                        <core:Item key="Training Room" text="Training Room" />
                    </items>
                </ComboBox>

                <!-- Department -->
                <Label text="Department" />
                <ComboBox id="dept" items="{local>/department}">
    <core:Item key="{local>department}" text="{local>department}" />
</ComboBox>

                <!-- Employee -->
                <Label text="Employee" />
                <Input id="emp" placeholder="Enter Employee Name" />

                <!-- Date -->
                <Label text="Date" />
                <DatePicker id="date" />

                <!-- Time -->
                <Label text="Time" />
                <Input id="timee" placeholder="Select Slot" />

           

                <!-- Slots -->
                <Label text="Available Slots" />
                <HBox wrap="Wrap">
<Button
    text="09:00 AM"
    press="onSelectSlot"
    type="{= ${local>/slot09} ? 'Reject' : 'Accept' }"/>

<Button
    text="10:00 AM"
    press="onSelectSlot"
    type="{= ${local>/slot10} ? 'Reject' : 'Accept' }"/>

<Button
    text="11:00 AM"
    press="onSelectSlot"
    type="{= ${local>/slot11} ? 'Reject' : 'Accept' }"/>

<Button
    text="12:00 PM"
    press="onSelectSlot"
    type="{= ${local>/slot12} ? 'Reject' : 'Accept' }"/>

</HBox>
 <!-- Capacity -->
                <Label text="Capacity" />
                <Input id="capacity_of_member" type="Number" />

                <!-- Buttons -->
                <HBox class="sapUiSmallMarginTop">
                    <Button text="Book Slot" type="Emphasized" press="onBook" />
                    <Button text="Reset" type="Reject" press="onReset" />
                    <Button text="Fetch Booked Slots" press="onFetchBookedSlots" />
                </HBox>

            </VBox>


            <VBox>
                <Title text="BOOKED SLOTS (Backend Data)" level="H3"/>

                <List
                    id="bookingList"
                    items="{/BookingSet01}"
                    class="sapUiSmallMarginTop">

                    <StandardListItem
                        title="{Employee} - {Department}"
                        description="{BookDate} | {BookTime} | Capacity: {Capacity}" />

                </List>
            </VBox>

        </content>
    </Page>
</mvc:View>